# Database
DATABASE_URL=postgres://oblimap:changeme@192.168.1.1:5432/oblimap

# Server
PORT=3002
NODE_ENV=development
SESSION_SECRET=change-me-in-production

# CORS — URL of the client app
CLIENT_ORIGIN=http://localhost:5174

# App URL — used in password reset emails
APP_URL=http://localhost:5174

# App name
APP_NAME=Oblimap

# Default admin credentials (first run only)
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# Set to "true" if behind HTTPS reverse proxy
FORCE_HTTPS=false

# Set to "true" to skip forced 2FA requirement during dev
DISABLE_2FA_FORCE=false

# Obliguard integration (optional)
OBLIGUARD_URL=
OBLIGUARD_SSO_SECRET=

# Obliview integration (optional)
OBLIVIEW_URL=
OBLIVIEW_SSO_SECRET=
