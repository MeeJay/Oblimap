# ── Image version (tag Docker Hub, ex: latest, 1.0.0) ──
OBLIMAP_VERSION=latest

# ── Database ──
# If using the built-in postgres container (docker-compose.yml):
DB_PASSWORD=changeme

# If using an external PostgreSQL (docker-compose.external-db.yml):
# DATABASE_URL=postgres://oblimap:yourpassword@your-db-host:5432/oblimap

# ── Server ──
PORT=3002
NODE_ENV=production
SESSION_SECRET=change-this-to-a-random-secret

# ── Client origin (for CORS — set to your actual URL) ──
CLIENT_ORIGIN=http://localhost
# LISTEN_PORT=3000

# ── App name ──
APP_NAME=Oblimap

# ── Default admin (created on first run) ──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── Set to "true" if behind HTTPS reverse proxy ──
FORCE_HTTPS=false

# ── Enable Watchtower and define the check interval to keep the containers up to date ──
#COMPOSE_PROFILES=watchtower
#WATCHTOWER_INTERVAL=3600
