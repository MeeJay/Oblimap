# ── Image version (tag Docker Hub, ex: latest, 1.0.0) ──
OBLIMAP_VERSION=latest

# ── Database password ──
# Default: changeme — change this in production
DB_PASSWORD=changeme

# ── Server ──
SESSION_SECRET=change-this-to-a-random-secret

# ── Client origin (for CORS — set to your actual URL) ──
CLIENT_ORIGIN=http://localhost
LISTEN_PORT=3002

# ── App name ──
APP_NAME=Oblimap

# ── Default admin (created on first run) ──
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=admin123

# ── Set to "true" if behind HTTPS reverse proxy ──
FORCE_HTTPS=false


