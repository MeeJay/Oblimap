<!--
  WinSW config for Obliview Agent.
  This file is installed alongside ObliviewService.exe (WinSW) in the install folder.
  The <arguments> element is rewritten at install time by the MSI (WiX util:XmlConfig).
-->
<service>
  <id>ObliviewAgent</id>
  <name>Obliview Monitoring Agent</name>
  <description>Sends system metrics to the Obliview monitoring platform.</description>
  <executable>%BASE%\obliview-agent.exe</executable>
  <arguments>--url "" --key ""</arguments>
  <onfailure action="restart" delay="10 sec"/>
  <onfailure action="restart" delay="30 sec"/>
  <onfailure action="restart" delay="60 sec"/>
  <log mode="none"/>
</service>
