<?xml version="1.0" encoding="utf-8"?>
<!--
  Oblimap Agent - Windows MSI Installer
  Built with WiX v4+ on Windows.

  Prerequisites (one-time setup):
    dotnet tool install -g wix
    go install (Go 1.22+, https://go.dev/dl)

  Build (from agent/ directory):
    build-msi.bat

  Install command:
    msiexec /i oblimap-agent.msi SERVERURL="https://..." APIKEY="your-key" /quiet
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Oblimap Agent"
           Manufacturer="Oblimap"
           Version="AGENT_VERSION_PLACEHOLDER"
           Language="1033"
           UpgradeCode="5C2D4E1F-8A3B-6789-CDEF-EF0123456780">

    <MajorUpgrade DowngradeErrorMessage="A newer version of Oblimap Agent is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <!-- Properties passed via: msiexec /i ... SERVERURL="..." APIKEY="..." -->
    <Property Id="SERVERURL" Secure="yes" />
    <Property Id="APIKEY" Secure="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OblimapAgent">

        <!--
          The Go binary is a proper Windows service executable.
          SERVERURL and APIKEY are passed as service arguments on first install;
          the agent then writes config.json and reads it on subsequent starts.
          DefaultVersion forces MSI to always overwrite the exe even when the
          binary has no Win32 version resource (Go binaries are unversioned).
        -->
        <Component Id="AgentExe" Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234560001">
          <File Id="AgentExeFile" Source="dist\oblimap-agent.exe" Name="oblimap-agent.exe"
                DefaultVersion="65535.0.0.0" />
          <ServiceInstall Id="AgentSvc"
                          Name="OblimapAgent"
                          DisplayName="Oblimap Monitoring Agent"
                          Description="Sends system metrics to the Oblimap monitoring platform."
                          Start="auto"
                          Type="ownProcess"
                          Account="LocalSystem"
                          ErrorControl="normal"
                          Arguments='--url "[SERVERURL]" --key "[APIKEY]"' />
          <ServiceControl Id="AgentSvcStart" Name="OblimapAgent" Start="install" />
          <ServiceControl Id="AgentSvcStop"  Name="OblimapAgent" Stop="both" Remove="uninstall" Wait="yes" />
        </Component>

        <!-- Registry fallback: agent reads these on first run if config.json is absent -->
        <Component Id="AgentConfig" Guid="B2C3D4E5-F6A7-8901-BCDE-EF1234560002">
          <RegistryValue Root="HKLM" Key="SOFTWARE\OblimapAgent"
                         Name="ServerUrl" Type="string" Value="[SERVERURL]" KeyPath="yes" />
          <RegistryValue Root="HKLM" Key="SOFTWARE\OblimapAgent"
                         Name="ApiKey"    Type="string" Value="[APIKEY]" />
        </Component>

      </Directory>
    </StandardDirectory>

    <Feature Id="Main">
      <ComponentRef Id="AgentExe" />
      <ComponentRef Id="AgentConfig" />
    </Feature>

  </Package>
</Wix>
